      "chapter_title": "\uc8fc\uc2dd\ud22c\uc790\uc758 \ub4f1\ub300 PER",
      "character_directions": {
        "expression": "worried",
        "pose": "slumped shoulders",
        "action": "\ube48 \uc9c0\uac11\uc744 \ub9cc\uc9c0\uc791\uac70\ub9ac\ub2e4\uac00, \ub4f1\ub300\uac00 \ub098\ud0c0\ub098\uc790 \ub208\uc774 \ud718\ub465\uadf8\ub808\uc9c0\uba70 \uace0\uac1c\ub97c \ub4dc\ub294 \ubaa8\uc2b5"
      }
