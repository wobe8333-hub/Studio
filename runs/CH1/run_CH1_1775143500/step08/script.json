  ],
  "hook": {
    "text": "\ub2f9\uc2e0\uc758 \uc8fc\uc2dd \uacc4\uc88c, \uc9c0\uae08 \uc548\ub155\ud558\uc2e0\uac00\uc694? \ud639\uc2dc \uc544\ubb34\uac83\ub3c4 \ubaa8\ub978 \ucc44 '\uac10'\uc73c\ub85c \ud22c\uc790\ud558\uace0 \uacc4\uc2e0\uac00\uc694? \uc218\ub9ce\uc740 \ud22c\uc790\uc790\ub4e4\uc774 \ub9e4\uc77c \uc8fc\uc2dd \uc2dc\uc7a5\uc5d0\uc11c \ud070 \ub3c8\uc744 \uc783\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uac71\uc815 \ub9c8\uc138\uc694! \uc624\ub298 \uc774 \uc601\uc0c1\uc744 \ub05d\uae4c\uc9c0 \ubcf4\uc2dc\uba74, \ub354 \uc774\uc0c1 '\ubb3b\uc9c0\ub9c8 \ud22c\uc790'\ub85c \ub3c8\uc744 \ub0a0\ub9ac\ub294 \uc77c\uc740 \uc5c6\uc744 \uac81\ub2c8\ub2e4. \ub531 11\ubd84\ub9cc \uc9d1\uc911\ud558\uc138\uc694. \uc8fc\uc2dd \ud22c\uc790\uc758 \ud575\uc2ec \uc9c0\ud45c 'PER'\uc744 \uc644\ubcbd\ud558\uac8c \uc774\ud574\ud558\uace0, \uc228\uaca8\uc9c4 \ubcf4\uc11d \uac19\uc740 \uc885\ubaa9\uc744 \ucc3e\ub294 \ubc29\ubc95\uc744 \uc54c\ub824\ub4dc\ub9b4\uac8c\uc694. \uc774\uc81c\ub294 \ub3c8\uc744 \uc9c0\ud0a4\uace0, \ud604\uba85\ud55c \ud22c\uc790\ub85c \ub3c8\uc744 \ubc8c \ucc28\ub840\uc785\ub2c8\ub2e4!",
    "duration_estimate_sec": 35,
    "hook_type": "\ucda9\uaca9\uc0ac\uc2e4",
    "hook_direction": "\uacbd\uc81c\uc801 \uc190\uc2e4 \uacf5\ud3ec + \uae30\ud68c \uc81c\uc2dc",
    "animation_preview_at_sec": 8
  },
  "promise": "\uc774 \uc601\uc0c1\uc5d0\uc11c PER(\uc8fc\uac00\uc218\uc775\ube44\uc728)\uc758 \uc791\ub3d9 \uc6d0\ub9ac\ub97c \uc644\ubcbd\ud788 \uc774\ud574\ud558\uace0, \uc774\ub97c \ud65c\uc6a9\ud558\uc5ec \uc800\ud3c9\uac00\ub41c \uc885\ubaa9\uc744 \ucc3e\uc544\ub0b4\uc5b4 \ub2f9\uc2e0\uc758 \ud22c\uc790 \uc218\uc775\uc744 \uadf9\ub300\ud654\ud558\ub294 \uc2e4\uc804 \uc804\ub7b5\uc744 \ubc30\uc6b0\uac8c \ub420 \uac83\uc785\ub2c8\ub2e4.",
  "sections": [
    {
      "id": 0,
      "heading": "\uc778\ud2b8\ub85c: \ub2f9\uc2e0\uc758 \uc8fc\uc2dd \ud22c\uc790\uac00 \uc704\ud5d8\ud55c \uc774\uc720 (\uacf5\ud3ec + \uae30\ud68c)",
      "narration_text": "\uc5ec\ub7ec\ubd84, \uc8fc\uc2dd \ud22c\uc790 \uc815\ub9d0 \uc5b4\ub835\uc8e0? \uc8fc\ubcc0\uc5d0\uc120 \ub204\uac00 \ubb58\ub85c \ub3c8 \ubc8c\uc5c8\ub2e4\ub354\ub77c, \ubb34\uc2a8 \uc885\ubaa9\uc774 \ub300\ubc15\uc774\ub77c\ub354\ub77c \ud558\ub294 \uc598\uae30\uc5d0 \uc194\uae43\ud574\uc11c \ubb34\ud131\ub300\uace0 \ud22c\uc790\ud588\ub2e4\uac00 \uc190\uc2e4\uc744 \ubcf4\ub294 \uacbd\uc6b0\uac00 \ud5c8\ub2e4\ud569\ub2c8\ub2e4. \ub9c8\uce58 \uce60\ud751 \uac19\uc740 \uc5b4\ub460 \uc18d\uc5d0\uc11c \ub4f1\ub300 \ud558\ub098 \uc5c6\uc774 \ud56d\ud574\ud558\ub294 \ubc30\uc640 \uac19\uc8e0. \ub2f9\uc2e0\uc758 \uc18c\uc911\ud55c \ub3c8\uc774 \uadf8\ub807\uac8c \uc704\ud5d8\uc5d0 \ub178\ucd9c\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uac71\uc815 \ub9c8\uc138\uc694! \uc624\ub298 \uc81c\uac00 \uc5ec\ub7ec\ubd84\uc5d0\uac8c \uadf8 \uc5b4\ub460\uc744 \ubc1d\ud600\uc904 \uac15\ub825\ud55c \ub4f1\ub300, \ubc14\ub85c 'PER' \uc9c0\ud45c\ub97c \uc18c\uac1c\ud574 \ub4dc\ub9b4 \uac81\ub2c8\ub2e4. \uc774 \uc9c0\ud45c \ud558\ub098\ub9cc \uc81c\ub300\ub85c \uc54c\uc544\ub3c4, \uc4f8\ub370\uc5c6\ub294 \uc190\uc2e4\uc744 \ub9c9\uace0 \uc624\ud788\ub824 \uae30\ud68c\ub97c \ud3ec\ucc29\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. PER\uc774 \ub300\uccb4 \ubb34\uc5c7\uc774\uace0, \uc5b4\ub5bb\uac8c \uc6b0\ub9ac \ub3c8\uc744 \uc9c0\ud0a4\uace0 \ub298\ub824\uc8fc\ub294\uc9c0 \uc9c0\uae08\ubd80\ud130 \uc790\uc138\ud788 \ud30c\ud5e4\uccd0 \ubd05\uc2dc\ub2e4.",
      "animation_prompt": "A character is seen looking worriedly at a downward-trending stock chart, holding a nearly empty wallet. Then, a bright lighthouse appears in the distance, shining a light onto a map. The character's expression changes to hope and determination.",
      "animation_style": "storytelling",
