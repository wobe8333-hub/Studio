      "manim_fallback_used": false,
      "chapter_title": "PER\uc758 \ub73b\uacfc \uacf5\uc2dd",
      "character_directions": {
        "expression": "curious",
        "pose": "pointing to blackboard",
        "action": "\uce60\ud310\uc758 \uacf5\uc2dd\uc744 \uc190\uac00\ub77d\uc73c\ub85c \uac00\ub9ac\ud0a4\uba70 \uace0\uac1c\ub97c \uac38\uc6c3\ud558\ub2e4\uac00, \ube44\uc720 \uc124\uba85\uc5d0 \uace0\uac1c\ub97c \ub044\ub355\uc774\uba70 \uc774\ud574\ud558\ub294 \ubaa8\uc2b5"
      }
