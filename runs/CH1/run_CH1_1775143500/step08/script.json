    {
      "id": 3,
      "heading": "PER, \ub9cc\ub2a5\uc740 \uc544\ub2c8\ub2e4! (\uc7a5\uc810\uacfc \ud55c\uacc4 \uc815\ud655\ud788 \uc54c\uae30)",
      "narration_text": "PER\uc774 \uc8fc\uc2dd \ud22c\uc790\uc5d0 \uc544\uc8fc \uc720\uc6a9\ud55c \uc9c0\ud45c\uc778 \uac83\uc740 \ubd84\uba85\ud569\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uc5b4\ub5a4 \uc9c0\ud45c\ub4e0 \ub9cc\ub2a5\uc740 \uc5c6\uc2b5\ub2c8\ub2e4. PER \uc5ed\uc2dc \uc7a5\uc810\uacfc \ud55c\uacc4\ub97c \uba85\ud655\ud788 \uc774\ud574\ud558\uace0 \uc0ac\uc6a9\ud574\uc57c \ud569\ub2c8\ub2e4. \uba3c\uc800, PER\uc758 **\uc7a5\uc810**\uc740 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4. \uccab\uc9f8, \uc9c1\uad00\uc801\uc785\ub2c8\ub2e4. \uae30\uc5c5\uc758 \uc218\uc775 \ub300\ube44 \uc8fc\uac00\ub97c \uc27d\uac8c \uc774\ud574\ud560 \uc218 \uc788\uc8e0. \ub458\uc9f8, \ube44\uad50\uac00 \uc6a9\uc774\ud569\ub2c8\ub2e4. \uac19\uc740 \uc0b0\uc5c5 \ub0b4 \uacbd\uc7c1\uc0ac \uc8fc\uc2dd\uc744 \ube44\uad50\ud560 \ub54c \uc544\uc8fc \uc720\uc6a9\ud569\ub2c8\ub2e4. \uc14b\uc9f8, \uae30\uc5c5\uc758 \uac00\uce58\ub97c \ub300\ub7b5\uc801\uc73c\ub85c \ud3c9\uac00\ud558\ub294 \uae30\uc900\uc73c\ub85c \uc0bc\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub7ec\ub098 **\ud55c\uacc4\uc810**\ub3c4 \ubd84\uba85\ud569\ub2c8\ub2e4. \uccab\uc9f8, \uc5c5\uc885\ubcc4 \ucc28\uc774\uac00 \ud07d\ub2c8\ub2e4. \uc131\uc7a5\uc131\uc774 \ub192\uc740 IT \uae30\uc5c5\uc774\ub098 \ubc14\uc774\uc624 \uae30\uc5c5\uc740 \ubbf8\ub798 \uc131\uc7a5 \uae30\ub300\uac10 \ub54c\ubb38\uc5d0 \ud604\uc7ac \uc218\uc775 \ub300\ube44 \ub192\uc740 PER\uc744 \ubc1b\ub294 \uacbd\uc6b0\uac00 \ub9ce\uace0, \ubc18\ub300\ub85c \uacbd\uae30 \ubbfc\uac10\uc8fc\ub098 \uc804\ud1b5 \uc0b0\uc5c5 \uae30\uc5c5\uc740 PER\uc774 \ub0ae\uc740 \uacbd\ud5a5\uc774 \uc788\uc2b5\ub2c8\ub2e4. \ub530\ub77c\uc11c \ub2e4\ub978 \uc5c5\uc885 \uac04\uc758 \ub2e8\uc21c \ube44\uad50\ub294 \uc758\ubbf8\uac00 \uc5c6\uc2b5\ub2c8\ub2e4. \ub458\uc9f8, \uc77c\ud68c\uc131 \uc774\uc775\uc774\ub098 \uc190\uc2e4\uc774 PER\uc744 \uc65c\uace1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, \uc790\uc0b0 \ub9e4\uac01\uc73c\ub85c \uc77c\uc2dc\uc801\uc778 \ud070 \uc774\uc775\uc744 \ub0c8\ub2e4\uba74 PER\uc774 \ub0ae\uc544 \ubcf4\uc77c \uc218 \uc788\uc8e0. \uc14b\uc9f8, \ubbf8\ub798 \uc131\uc7a5\uc131\uc744 \ucda9\ubd84\ud788 \ubc18\uc601\ud558\uc9c0 \ubabb\ud569\ub2c8\ub2e4. \ud604\uc7ac \uc218\uc775\uc774 \uc801\ub354\ub77c\ub3c4 \ubbf8\ub798\uc5d0 \ud3ed\ubc1c\uc801\uc778 \uc131\uc7a5\uc774 \uae30\ub300\ub418\ub294 \uae30\uc5c5\uc740 \ub192\uc740 PER\uc744 \uc815\ub2f9\ud654\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub7ec\ubbc0\ub85c PER\ub9cc\uc73c\ub85c \uc123\ubd88\ub9ac \ud22c\uc790 \uacb0\uc815\uc744 \ub0b4\ub9ac\ub294 \uac83\uc740 \uc704\ud5d8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc774 \uc810\uc744 \ubc18\ub4dc\uc2dc \uba85\uc2ec\ud574\uc57c \ud569\ub2c8\ub2e4.",
