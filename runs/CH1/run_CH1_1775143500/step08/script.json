    "PER 1\ubd84\ucef7 \uc644\ubcbd\uc774\ud574! \ub0b4 \ub3c8 \uc9c0\ud0a4\uace0 \uc783\ub294 \ud22c\uc790\ub97c \uba48\ucd94\ub294 \ubc95",
    "\uc8fc\uc2dd \ud22c\uc790\uc790 \ud544\ub3c5! PER \uc774 \uc9c0\ud45c \ubaa8\ub974\uba74 \ub3c8 \uc783\uc2b5\ub2c8\ub2e4 (Feat. 1\ubd84\ucef7)",
