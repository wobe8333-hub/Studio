    {
      "id": 4,
      "heading": "\ub0b4 \ub3c8\uc744 \uc9c0\ud0a4\ub294 PER \ud65c\uc6a9\ubc95 (\uc2e4\uc804 \uc801\uc6a9 \uac00\uc774\ub4dc)",
      "narration_text": "\uadf8\ub807\ub2e4\uba74 \uc774 \uc720\uc6a9\ud55c PER \uc9c0\ud45c\ub97c \uc5b4\ub5bb\uac8c \uc2e4\uc804\uc5d0\uc11c \ud65c\uc6a9\ud574\uc57c \ub0b4 \ub3c8\uc744 \uc9c0\ud0a4\uace0 \uc624\ud788\ub824 \ubd88\ub9b4 \uc218 \uc788\uc744\uae4c\uc694? \uc138 \uac00\uc9c0 \ud575\uc2ec \ud65c\uc6a9\ubc95\uc744 \uc54c\ub824\ub4dc\ub9ac\uaca0\uc2b5\ub2c8\ub2e4. \uccab\uc9f8, **\ub3d9\uc885 \uc5c5\uacc4 \ub0b4 \uacbd\uc7c1\uc0ac PER \ube44\uad50**\uc785\ub2c8\ub2e4. A\ub77c\ub294 \ubc18\ub3c4\uccb4 \uae30\uc5c5\uc5d0 \ud22c\uc790\ud558\uace0 \uc2f6\ub2e4\uba74, \uad6d\ub0b4\uc678 \ub2e4\ub978 \ubc18\ub3c4\uccb4 \uae30\uc5c5\ub4e4\uc758 PER\uc744 \ube44\uad50\ud574 \ubcf4\uc138\uc694. \ub9cc\uc57d A \uae30\uc5c5\uc758 PER\uc774 \uacbd\uc7c1\uc0ac\ub4e4\ubcf4\ub2e4 \ud604\uc800\ud788 \ub0ae\ub2e4\uba74, \uc800\ud3c9\uac00\ub418\uc5b4 \uc788\uc744 \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4. \ubc18\ub300\ub85c \ub108\ubb34 \ub192\ub2e4\uba74 \uacfc\uc5f4\ub418\uc5c8\uc744 \uc218\ub3c4 \uc788\uc8e0. \ub458\uc9f8, **\ud574\ub2f9 \uae30\uc5c5\uc758 \uacfc\uac70 PER \ucd94\uc774 \ubd84\uc11d**\uc785\ub2c8\ub2e4. \ud604\uc7ac PER\uc774 \uacfc\uac70 3\ub144, 5\ub144 \ud3c9\uade0 PER\uacfc \ube44\uad50\ud558\uc5ec \uc5b4\ub5a4 \uc218\uc900\uc778\uc9c0 \uc0b4\ud3b4\ubcf4\ub294 \uac81\ub2c8\ub2e4. \uacfc\uac70 \ud3c9\uade0\ubcf4\ub2e4 \ub0ae\ub2e4\uba74 \uc9c0\uae08\uc774 \ub9e4\uc218 \uc801\uae30\uc77c \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc14b\uc9f8, **\uc2dc\uc7a5 \ud3c9\uade0 PER\uacfc\uc758 \ube44\uad50**\uc785\ub2c8\ub2e4. \ucf54\uc2a4\ud53c\ub098 \ucf54\uc2a4\ub2e5 \uc2dc\uc7a5 \uc804\uccb4\uc758 \ud3c9\uade0 PER\uacfc \ube44\uad50\ud558\uc5ec \ud2b9\uc815 \uc885\ubaa9\uc758 \uc0c1\ub300\uc801 \uc704\uce58\ub97c \ud30c\uc545\ud558\ub294 \uac70\uc8e0. \ubb3c\ub860 \uc774 \uc138 \uac00\uc9c0 \ubc29\ubc95 \ubaa8\ub450 '\uc65c' PER\uc774 \uadf8\ub7f0\uc9c0 \uadf8 \uc774\uc720\ub97c \ubc18\ub4dc\uc2dc \ud30c\uace0\ub4e4\uc5b4\uc57c \ud569\ub2c8\ub2e4. \ub2e8\uc21c\ud788 \uc22b\uc790\uac00 \ub0ae\ub2e4\uace0 \ubb34\uc870\uac74 \uc88b\uc740 \uac83\uc774 \uc544\ub2c8\ub77c, \uadf8 \ubc30\uacbd\uc5d0 \uae30\uc5c5\uc758 \uc2e4\uc801 \uac1c\uc120 \uae30\ub300\uac10\uc774\ub098 \uc77c\uc2dc\uc801\uc778 \uc545\uc7ac \ud574\uc18c \uac19\uc740 \uae0d\uc815\uc801\uc778 \uc694\uc778\uc774 \uc788\ub294\uc9c0 \ud655\uc778\ud574\uc57c \ud569\ub2c8\ub2e4. \uc774\ucc98\ub7fc \ube44\uad50 \ubd84\uc11d\uc744 \ud1b5\ud574 PER\uc744 \ud65c\uc6a9\ud55c\ub2e4\uba74, \uc783\uc744 \uac71\uc815\uc744 \uc904\uc774\uace0 \uc218\uc775 \uae30\ud68c\ub97c \ud3ec\ucc29\ud558\ub294 \ub370 \ud070 \ub3c4\uc6c0\uc774 \ub420 \uac81\ub2c8\ub2e4.",
      "animation_prompt": "A character is demonstrating on a large interactive screen. Three distinct panels appear: 1. 'Competitor Comparison Chart' (showing PERs of several companies in the same industry). 2. 'Historical PER Trend Line' (a line graph of a company's PER over 5 years). 3. 'Market Average PER Comparison' (a bar chart comparing a company's PER to KOSPI/KOSDAQ average). The character points to key findings on each panel.",
      "animation_style": "demonstration",
      "render_tool": "manim",
      "manim_code": null,
      "manim_fallback_used": false,
      "chapter_title": "PER \uc2e4\uc804 \uc804\ub7b5 3\uac00\uc9c0",
      "character_directions": {
        "expression": "confident",
        "pose": "pointing and explaining",
        "action": "\ucee4\ub2e4\ub780 \ud654\uba74 \uc55e\uc5d0\uc11c \uc190\uac00\ub77d\uc73c\ub85c \ucc28\ud2b8\ub97c \uac00\ub9ac\ud0a4\uba70 \ud575\uc2ec \ud3ec\uc778\ud2b8\ub97c \uc124\uba85\ud558\ub294 \ubaa8\uc2b5"
      }
