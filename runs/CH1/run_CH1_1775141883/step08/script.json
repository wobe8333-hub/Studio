      "manim_fallback_used": false,
      "chapter_title": "\uc2e4\uc2dc\uac04 \uc815\ubcf4, \uadf8 \uc774\uba74\uc758 \uc9c4\uc2e4",
      "character_directions": {
        "expression": "explaining/knowledgeable",
        "pose": "pointing/gesturing",
        "action": "\ud654\uba74\uc5d0 \ub098\ud0c0\ub098\ub294 \ud50c\ub85c\uc6b0\ucc28\ud2b8\ub97c \uc190\uac00\ub77d\uc73c\ub85c \uac00\ub9ac\ud0a4\uba70 \uc5f4\uc815\uc801\uc73c\ub85c \uc124\uba85\ud558\uace0, \uc911\uac04\uc5d0 \uc548\uacbd\uc744 \uace0\uccd0 \uc4f0\ub294 \ub4ef\ud55c \ub3d9\uc791\uc744 \ucde8\ud55c\ub2e4."
      }
    },
    {
      "id": 2,
      "heading": "\uc815\ubcf4\uc758 \ubc14\ub2e4, \ud544\ud130\ub9c1\uc758 \uc911\uc694\uc131",
      "narration_text": "\ub9e4\uc77c \uc3df\uc544\uc9c0\ub294 \uc815\ubcf4\uc758 \ud64d\uc218 \uc18d\uc5d0\uc11c \uc5b4\ub5a4 \uc815\ubcf4\uac00 \uc9c4\uc9dc\ubc30\uae30\uc774\uace0, \uc5b4\ub5a4 \uc815\ubcf4\uac00 \ud758\ub824\ubcf4\ub0b4\uc57c \ud560 \uac83\uc778\uc9c0 \uad6c\ubcc4\ud558\ub294 \uac83\uc740 \ub9c8\uce58 \uc9c4\ud759\ud0d5 \uc18d\uc5d0\uc11c \uc9c4\uc8fc\ub97c \ucc3e\ub294 \uac83\uacfc \uac19\uc2b5\ub2c8\ub2e4. \uacbd\uc81c \ubc29\uc1a1\uc758 \uc815\ubcf4\ub294 \ud06c\uac8c \ub450 \uac00\uc9c0 \ubc29\uc2dd\uc73c\ub85c \ud3b8\ud5a5\ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uccab\uc9f8, '\uc120\ud0dd\uc801 \uc815\ubcf4 \uc81c\uacf5'\uc785\ub2c8\ub2e4. \ud2b9\uc815 \uae30\uc5c5\uc774\ub098 \uc0b0\uc5c5\uc5d0 \uc720\ub9ac\ud55c \uc815\ubcf4\ub9cc\uc744 \ubd80\uac01\ud558\uace0 \ubd88\ub9ac\ud55c \uc815\ubcf4\ub294 \ucd95\uc18c\ud558\uac70\ub098 \ubc30\uc81c\ud558\ub294 \uacbd\uc6b0\uac00 \uc788\uc2b5\ub2c8\ub2e4. \uc774\ub294 \ubc29\uc1a1\uc0ac\uc758 \uad11\uace0\uc8fc \uad00\uacc4\ub098 \ud2b9\uc815 \uc804\ubb38\uac00\uc758 \uc774\ud574\uad00\uacc4\uc640 \uc5bd\ud600\uc788\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub458\uc9f8, '\uac10\uc131\uc801 \ud3b8\ud5a5'\uc785\ub2c8\ub2e4. \uc2dc\uc7a5\uc758 \uacfc\uc5f4\uc774\ub098 \ubd88\uc548\uac10\uc744 \uc870\uc7a5\ud558\uc5ec \uc2dc\uccad\uc790\ub4e4\uc758 \uc774\uc131\uc801\uc778 \ud310\ub2e8\uc744 \ubc29\ud574\ud558\uae30\ub3c4 \ud569\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, \ud2b9\uc815 \uc885\ubaa9\uc758 \uae09\ub4f1 \uc18c\uc2dd\uc744 \uacfc\uc7a5\ud558\uc5ec \ubcf4\ub3c4\ud568\uc73c\ub85c\uc368 '\ub098\ub9cc \ub4a4\ucc98\uc9c0\ub294 \uac83 \uc544\ub2d0\uae4c?' \ud558\ub294 FOMO(Fear Of Missing Out) \uc2ec\ub9ac\ub97c \uc790\uadf9\ud558\ub294 \uac83\uc774\uc8e0. \uc6b0\ub9ac\uac00 \ub9c8\uc2dc\ub294 \ubb3c\ub3c4 \ud544\ud130\ub9c1\uc744 \uac70\uccd0\uc57c \uae68\ub057\ud574\uc9c0\ub4ef\uc774, \uacbd\uc81c \uc815\ubcf4 \uc5ed\uc2dc \uc6b0\ub9ac\ub9cc\uc758 \ud544\ud130\ub97c \ud1b5\ud574 \uac78\ub7ec\ub0b4\uc57c \uc21c\ub3c4 \ub192\uc740 \uc815\ubcf4\ub85c \ub9cc\ub4e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
      "animation_prompt": "A split screen comparison. On one side, a clear glass of water with a filter (representing unbiased, processed information). On the other, a murky, unfiltered glass of water with various bits floating (representing raw, potentially biased information). An animated character holds a magnifying glass over the unfiltered water, then uses a filter to make it clear, illustrating the filtering process. Show a thought bubble with a company logo next to an analyst, hinting at potential bias.",
      "animation_style": "comparison",
      "render_tool": "manim",
      "manim_code": null,
      "manim_fallback_used": false,
      "chapter_title": "\uc815\ubcf4 \ud3b8\ud5a5\uacfc \ubbf8\ub514\uc5b4 \ub9ac\ud130\ub7ec\uc2dc",
      "character_directions": {
        "expression": "thinking/critical",
        "pose": "questioning/examining",
        "action": "\uc591\uc190\uc73c\ub85c \ub3cb\ubcf4\uae30\ub97c \ub4e4\uace0 \ud654\uba74 \uc18d \uc815\ubcf4\ub97c \uc720\uc2ec\ud788 \uc0b4\ud3b4\ubcf4\ub294 \ub4ef\ud55c \ub3d9\uc791\uc744 \ucde8\ud558\uba70, \uace0\uac1c\ub97c \uac38\uc6c3\uac70\ub9b0\ub2e4."
      }
    },
    {
      "id": 3,
      "heading": "\uac10\uc131\uc801 \uc790\uadf9\uacfc \uc2dc\uc7a5\uc758 \ubc18\uc751: FOMO\ub97c \uacbd\uacc4\ud558\ub77c!",
      "narration_text": "\uacbd\uc81c \ubc29\uc1a1\uc758 \ub77c\uc774\ube0c \ud2b9\uc131\uc740 \uc2dc\uccad\uc790\ub4e4\uc758 \uac10\uc815\uc744 \uac15\ud558\uac8c \uc790\uadf9\ud558\ub294 \uacbd\ud5a5\uc774 \uc788\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \uc8fc\uc2dd \uc2dc\uc7a5\uc5d0\uc11c\ub294 '\uc9c0\uae08 \ub2f9\uc7a5 \uc0ac\uc57c \ud560 \uac83 \uac19\ub2e4', '\ube68\ub9ac \ud314\uc544\uc57c \uc190\uc2e4\uc744 \ub9c9\ub294\ub2e4' \uac19\uc740 \uae34\ubc15\ud55c \uba54\uc2dc\uc9c0\uac00 \ub04a\uc784\uc5c6\uc774 \uc3df\uc544\uc9d1\ub2c8\ub2e4. \uc774\ub7ec\ud55c \uba54\uc2dc\uc9c0\ub294 \ud22c\uc790\uc790\ub4e4\uc758 FOMO, \uc989 '\ub098\ub9cc \uae30\ud68c\ub97c \ub193\uce60\uae4c \ubd10 \ubd88\uc548\ud55c \uc2ec\ub9ac'\ub97c \uc790\uadf9\ud558\uac70\ub098, \ubc18\ub300\ub85c \ud328\ub2c9 \uc140\ub9c1\uc744 \uc720\ub3c4\ud558\uc5ec \uc774\uc131\uc801\uc778 \ud310\ub2e8\uc744 \ub9c8\ube44\uc2dc\ud0ac \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, \ud2b9\uc815 \uc8fc\uc2dd\uc758 \uae09\ub4f1\uc138\ub97c \ubcf4\uc5ec\uc8fc\uba70 '\uc9c0\uae08 \uc544\ub2c8\uba74 \uae30\ud68c\uac00 \uc5c6\ub2e4!'\ub294 \uc2dd\uc758 \ub258\uc559\uc2a4\ub97c \ud48d\uae30\uba74, \ub9ce\uc740 \uac1c\uc778 \ud22c\uc790\uc790\ub4e4\uc740 \uac80\ud1a0\ud560 \uc2dc\uac04\ub3c4 \uc5c6\uc774 \uc2dc\uc7a5\uc5d0 \ub6f0\uc5b4\ub4e4\uac8c \ub429\ub2c8\ub2e4. \uc774\ub294 \uc885\uc885 \uace0\uc810\uc5d0 \ubb3c\ub9ac\ub294 \uacb0\uacfc\ub97c \ub0b3\uace4 \ud569\ub2c8\ub2e4. \ubc18\ub300\ub85c, \uc2dc\uc7a5\uc5d0 \ub300\ud55c \ubd80\uc815\uc801\uc778 \uc804\ub9dd\uc774 \uc5f0\uc774\uc5b4 \ub098\uc624\uba74, \uc190\uc2e4\uc744 \ubcf4\ub354\ub77c\ub3c4 \uc77c\ub2e8 \ud314\uace0 \ubcf4\uc790\ub294 \uc2ec\ub9ac\uac00 \uac15\ud574\uc838 \uc800\uc810\uc5d0\uc11c \ub9e4\ub3c4\ud558\ub294 \uc2e4\uc218\ub85c \uc774\uc5b4\uc9c0\uae30\ub3c4 \ud569\ub2c8\ub2e4. \ub0c9\ucca0\ud55c \uc774\uc131\uc774 \ud544\uc694\ud55c \ud22c\uc790 \uc601\uc5ed\uc5d0\uc11c, \uac10\uc131\uc801 \uc790\uadf9\uc740 \uac00\uc7a5 \uacbd\uacc4\ud574\uc57c \ud560 \uc801\uc785\ub2c8\ub2e4.",
      "animation_prompt": "A split screen comparing two investors. One investor (left) is calm, researching on a laptop, making notes. The other investor (right) is panicked, looking at a fast-moving stock chart on a phone, sweating, eyes wide, showing 'FOMO' bubbles above their head. The panicked investor hastily presses a 'Buy' button, then shows regret. The calm investor smiles slightly. Show a graph with sharp peaks and valleys, illustrating impulsive buying/selling.",
      "animation_style": "comparison",
      "render_tool": "manim",
      "manim_code": null,
