{
  "title_candidates": [
    "\ud55c\uad6d\uacbd\uc81cTV LIVE, \ub2f9\uc2e0\uc758 \ub3c8\uc744 \uc9c0\ud0a4\ub294 \ube44\ubc95\uc740? \ubbf8\ub514\uc5b4\uc758 \uc228\uaca8\uc9c4 \uc601\ud5a5\ub825 \ud30c\ud5e4\uce58\uae30!",
    "\uc18d\uc9c0 \ub9c8\uc138\uc694! \ud55c\uad6d\uacbd\uc81cTV LIVE\uac00 \ub0b4 \ud22c\uc790\ub97c \ub9dd\uce60 \uc218\ub3c4 \uc788\ub2e4? \ud604\uba85\ud55c \uc2dc\uccad \uac00\uc774\ub4dc",
    "\uacbd\uc81c\ubc29\uc1a1, \uc591\ub0a0\uc758 \uac80! \ud55c\uad6d\uacbd\uc81cTV LIVE \uc791\ub3d9 \uc6d0\ub9ac\ubd80\ud130 \ub0b4 \ub3c8 \uad00\ub9ac\ubc95\uae4c\uc9c0 \uc644\ubcbd \ud574\ubd80"
  ],
  "hook": {
    "text": "\uc624\ub298\ub3c4 [\ud55c\uad6d\uacbd\uc81cTV LIVE]\ub97c \ubcf4\uba70 '\ub300\ubc15 \uc885\ubaa9'\uc5d0 \ub300\ud55c \uae30\ub300\ub97c \ud488\uc73c\uc168\ub098\uc694? \ud639\uc2dc \uadf8 \uc815\ubcf4\uac00 \ub2f9\uc2e0\uc758 \uc18c\uc911\ud55c \ud22c\uc790\uae08\uc744 \uc704\ud5d8\uc5d0 \ube60\ub728\ub9b4 \uc218\ub3c4 \uc788\ub2e4\ub294 \uc0ac\uc2e4, \uc54c\uace0 \uacc4\uc168\ub098\uc694? \uc218\ub9ce\uc740 \uacbd\uc81c \uc815\ubcf4 \uc18d\uc5d0\uc11c \uc798\ubabb\ub41c \ud310\ub2e8\uc740 \uce58\uba85\uc801\uc778 \uc190\uc2e4\ub85c \uc774\uc5b4\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uac71\uc815 \ub9c8\uc138\uc694! \uc774 \uc601\uc0c1\uc744 \ub05d\uae4c\uc9c0 \ubcf4\uc2dc\uba74, \ubbf8\ub514\uc5b4\uc758 \uc228\uaca8\uc9c4 \ud568\uc815\uc744 \ud53c\ud558\uace0 \uc624\ud788\ub824 \uae30\ud68c\ub85c \ubc14\uafb8\ub294 \ubc29\ubc95\uc744 \uc54c\uac8c \ub420 \uac81\ub2c8\ub2e4! \uc5ec\ub7ec\ubd84\uc758 \uc9c0\uac11\uc744 \uc9c0\ud0a4\ub294 \ud604\uba85\ud55c \uacbd\uc81c \ubbf8\ub514\uc5b4 \ud65c\uc6a9\ubc95, \uc9c0\uae08 \ubc14\ub85c \uc2dc\uc791\ud569\ub2c8\ub2e4.",
    "duration_estimate_sec": 45,
    "hook_type": "\ucda9\uaca9\uc0ac\uc2e4",
    "hook_direction": "\uacbd\uc81c\uc801 \uc190\uc2e4 \uacf5\ud3ec + \uae30\ud68c \uc81c\uc2dc",
    "animation_preview_at_sec": 8
