        "action": "\ud55c \uc190\uc740 \ud131\uc5d0 \ub300\uace0 \uace0\ubbfc\ud558\ub294 \ub4ef\ud55c \ud45c\uc815\uc73c\ub85c TV \ud654\uba74\uc744 \ubc14\ub77c\ubcf4\ub2e4\uac00, \uc774\ub0b4 \uacb0\uc2ec\ud55c \ub4ef \uace0\uac1c\ub97c \ub044\ub355\uc778\ub2e4."
      }
