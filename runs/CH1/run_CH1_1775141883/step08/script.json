  "promise": "\uc774 \uc601\uc0c1\uc5d0\uc11c [\ud55c\uad6d\uacbd\uc81cTV LIVE] \uac19\uc740 \uacbd\uc81c \ubc29\uc1a1\uc774 \uc5b4\ub5bb\uac8c \uc791\ub3d9\ud558\uace0, \uadf8\uac83\uc774 \uc5ec\ub7ec\ubd84\uc758 \ud22c\uc790 \uacb0\uc815\uacfc \uc790\uc0b0\uc5d0 \uc5b4\ub5a4 \uc601\ud5a5\uc744 \ubbf8\uce58\ub294\uc9c0 \uc815\ud655\ud788 \uc774\ud574\ud558\uba70, \ud604\uba85\ud55c \ud22c\uc790 \uc804\ub7b5\uc744 \uc138\uc6b8 \uc218 \uc788\ub294 \uc9c0\ud61c\ub97c \uc5bb\uac8c \ub420 \uac83\uc785\ub2c8\ub2e4.",
  "sections": [
    {
      "id": 0,
      "heading": "\uacbd\uc81c \ubc29\uc1a1, \uc591\ub0a0\uc758 \uac80\uc778\uac00?",
      "narration_text": "\uc5ec\ub7ec\ubd84 \uc548\ub155\ud558\uc138\uc694! \ub9e4\uc77c \uc544\uce68 \ud639\uc740 \uc800\ub141, \uc6b0\ub9ac\ub294 [\ud55c\uad6d\uacbd\uc81cTV LIVE]\uc640 \uac19\uc740 \uacbd\uc81c \ubc29\uc1a1\uc744 \ud1b5\ud574 \uc8fc\uc2dd \uc2dc\uc7a5\uc758 \ud750\ub984, \ubd80\ub3d9\uc0b0 \ub3d9\ud5a5, \uadf8\ub9ac\uace0 \uac01\uc885 \uacbd\uc81c \ub274\uc2a4\ub4e4\uc744 \uc811\ud569\ub2c8\ub2e4. \ube60\ub974\uace0 \uc0dd\uc0dd\ud55c \uc815\ubcf4\ub294 \ud22c\uc790\uc790\uc5d0\uac8c \ud544\uc218\uc801\uc774\uc8e0. \ud2b9\ud788 \uc2e4\uc2dc\uac04\uc73c\ub85c \uc3df\uc544\uc9c0\ub294 \uc815\ubcf4\ub294 \ub9c8\uce58 \uc2dc\uc7a5\uc758 \ub098\uce68\ubc18\ucc98\ub7fc \ub290\uaef4\uc9c8 \ub54c\uac00 \ub9ce\uc2b5\ub2c8\ub2e4. \ud558\uc9c0\ub9cc \uacfc\uc5f0 \uadf8 \uc815\ubcf4\ub4e4\uc774 \uc5b8\uc81c\ub098 \uc6b0\ub9ac\uc5d0\uac8c \uc774\ub85c\uc6b4 \ubc29\ud5a5\ub9cc\uc744 \uc81c\uc2dc\ud560\uae4c\uc694? \ub54c\ub85c\ub294 \ub2ec\ucf64\ud55c \uc720\ud639\ucc98\ub7fc \ub2e4\uac00\uc640 \uc6b0\ub9ac\uc758 \ud569\ub9ac\uc801\uc778 \ud310\ub2e8\uc744 \ud750\ub9ac\uac8c \ub9cc\ub4e4\uae30\ub3c4 \ud569\ub2c8\ub2e4. \ub9c8\uce58 \ubd88\ud655\uc2e4\ud55c \ubc14\ub2e4\ub97c \ud56d\ud574\ud558\ub294 \ubc30\uac00 \ub4f1\ub300\ub9cc\uc744 \ubbff\uace0 \ub098\uc544\uac00\ub2e4 \uc554\ucd08\uc5d0 \ubd80\ub52a\ud790 \uc218\ub3c4 \uc788\ub294 \uac83\ucc98\ub7fc\uc694. \uc6b0\ub9ac\ub294 \uc774 \ubc29\uc1a1\ub4e4\uc774 \uac00\uc9c4 \uc7a0\uc7ac\uc801\uc778 \uc704\ud5d8\uacfc \uae30\ud68c\ub97c \ub3d9\uc2dc\uc5d0 \uc774\ud574\ud574\uc57c \ud569\ub2c8\ub2e4. \ub2e8\uc21c\ud788 \uc815\ubcf4\ub97c \uc218\ub3d9\uc801\uc73c\ub85c \ubc1b\uc544\ub4e4\uc774\ub294 \uac83\uc744 \ub118\uc5b4, \ube44\ud310\uc801\uc778 \uc2dc\uac01\uc73c\ub85c \ubd84\uc11d\ud558\uace0 \uc6b0\ub9ac \uc2a4\uc2a4\ub85c \ud310\ub2e8\ud558\ub294 \ub2a5\ub825\uc744 \ud0a4\uc6b0\ub294 \uac83\uc774 \uc911\uc694\ud569\ub2c8\ub2e4. \uc774 \uc601\uc0c1\uc740 \ubc14\ub85c \uadf8 \uccab\uac78\uc74c\uc774 \ub420 \uac83\uc785\ub2c8\ub2e4.",
      "animation_prompt": "An animated character stands in front of a giant TV screen displaying dynamic stock charts and news tickers. On one side, a pathway leads to bright, growing money trees. On the other, a path leads to a dark, thorny bush with wilting money leaves. The character looks from the screen to the two paths, appearing thoughtful and slightly worried. The screen then splits into two, one showing positive news, the other negative, illustrating 'two-edged sword'.",
      "animation_style": "comparison",
      "render_tool": "manim",
