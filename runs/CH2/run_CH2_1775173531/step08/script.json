  "promise": "\uc774 \uc601\uc0c1\uc5d0\uc11c \ub2f9\uc2e0\uc740 '\ud53c\ud574\uc57c \ud560 \uc9d1' \ud2b8\ub80c\ub4dc\uac00 \ubd80\ub3d9\uc0b0 \uc2dc\uc7a5\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5\uc744 \uc815\ud655\ud788 \uc774\ud574\ud558\uace0, \ub0a8\ub4e4\uc774 \ud53c\ud560 \ub54c \uc624\ud788\ub824 \uae30\ud68c\ub97c \ud3ec\ucc29\ud558\uc5ec \uc131\uacf5\uc801\uc778 \ud22c\uc790\ub97c \uc774\ub044\ub294 \uc2e4\uc9c8\uc801\uc778 \ubc29\ubc95\uc744 \ubc30\uc6b8 \uac83\uc785\ub2c8\ub2e4.",
  "sections": [
    {
      "id": 0,
      "heading": "\ud83d\udea8 \uacbd\uace0: '\uc774\ub7f0 \uc9d1\uc740 \ud53c\ud558\uc138\uc694' \ud2b8\ub80c\ub4dc\uc758 \uc228\uaca8\uc9c4 \uc704\ud5d8!",
      "narration_text": "\uc548\ub155\ud558\uc138\uc694, \ud604\uba85\ud55c \ubd80\ub3d9\uc0b0 \ud22c\uc790\uc790 \uc5ec\ub7ec\ubd84! \uc624\ub298\uc740 \ub9e4\uc6b0 \uc911\uc694\ud55c \uc8fc\uc81c\ub97c \ub2e4\ub8f0 \uac70\uc608\uc694. \uc694\uc998 \"\uc774\ub7f0 \uc9d1\uc740 \uc808\ub300 \uc0ac\uc9c0 \ub9c8\uc138\uc694\", \"\uc774 \uc9d1\uc740 \ub625\uac12 \ub429\ub2c8\ub2e4\" \uac19\uc740 \uac15\ub82c\ud55c \uc81c\ubaa9\uc758 \ucf58\ud150\uce20\ub4e4\uc744 \uc2ec\uc2ec\ucc2e\uac8c \ubcf4\uc168\uc744 \uac81\ub2c8\ub2e4. \ud83d\udc42 \uc774\ub7f0 \uc815\ubcf4\ub4e4\uc774 \ub118\uccd0\ub098\ub294 \uac74 \uc2dc\uc7a5\uc5d0 \ub300\ud55c \uad00\uc2ec\uc774 \ud06c\ub2e4\ub294 \ubc18\uc99d\uc774\uae30\ub3c4 \ud558\uc9c0\ub9cc, \ub3d9\uc2dc\uc5d0 \uc5c4\uccad\ub09c \uc704\ud5d8\uc744 \ub0b4\ud3ec\ud558\uace0 \uc788\ub2e4\ub294 \uc0ac\uc2e4\uc744 \uc544\uc154\uc57c \ud569\ub2c8\ub2e4. \ud83e\udd2f \ud2b9\uc815 \uc9c0\uc5ed, \ud2b9\uc815 \uc720\ud615\uc758 \uc544\ud30c\ud2b8\ub97c \uc77c\ubc29\uc801\uc73c\ub85c '\ud53c\ud574\uc57c \ud560 \uc9d1'\uc73c\ub85c \ub099\uc778\ucc0d\ub294 \ud2b8\ub80c\ub4dc\ub294 \ub2e8\uae30\uc801\uc73c\ub85c\ub294 \uc0ac\ub78c\ub4e4\uc758 \ubd88\uc548\uac10\uc744 \uc99d\ud3ed\uc2dc\ud0a4\uace0, \uc7a5\uae30\uc801\uc73c\ub85c\ub294 \uc2dc\uc7a5\uc758 \ube44\ud569\ub9ac\uc801\uc778 \uc6c0\uc9c1\uc784\uc744 \uc720\ub3c4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ub9c8\uce58 \uc804\uc5fc\ubcd1\ucc98\ub7fc \ubc88\uc9c0\ub294 \uacf5\ud3ec \uc2ec\ub9ac\uac00 \uc815\ub9d0 \uac1d\uad00\uc801\uc778 \uac00\uce58 \ud310\ub2e8\uc744 \ubc29\ud574\ud558\uace0, \uc624\ud788\ub824 \uc5ec\ub7ec\ubd84\uc758 \uc18c\uc911\ud55c \uc790\uc0b0\uc744 \uc704\ud5d8\uc5d0 \ube60\ub728\ub9b4 \uc218 \uc788\ub2e4\ub294 \uc810, \uc808\ub300 \uac04\uacfc\ud574\uc11c\ub294 \uc548 \ub429\ub2c8\ub2e4!",
      "animation_prompt": "An animated cute rabbit character (Dr. Rabby) stands on a platform, looking concerned. In the background, speech bubbles with 'Avoid this house!', 'Bad investment!', 'Price will drop!' fly around, some hitting confused-looking house icons. Dr. Rabby points to a warning sign with a skull icon.",
      "animation_style": "comparison",
      "render_tool": "manim",
