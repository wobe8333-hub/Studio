{
  "title_candidates": [
    "\ud83d\udea8 \uc774\ub7f0 \uc9d1 \uc808\ub300 \ud53c\ud558\uc138\uc694? \uc704\ud5d8 \ub4a4 \uc228\uaca8\uc9c4 \uc5ed\ub300\uae09 \uae30\ud68c \ud3ec\ucc29\ubc95!",
    "\"\ud53c\ud574\uc57c \ud560 \uc9d1\" \ud2b8\ub80c\ub4dc, \ub2f9\uc2e0\uc758 \ud22c\uc790\uc5d0 \ub3c5\uc774 \ub420\uae4c? \ud83d\udc8a \uc190\uc2e4 \ud53c\ud558\uace0 \ub3c8 \ubc84\ub294 \ube44\ubc00!",
    "\ubd80\ub3d9\uc0b0 \ubc08\uc5d0 \uc18d\uc9c0 \ub9c8\uc138\uc694! '\ub625\uc9d1'\uc774\ub77c\uace0 \ub180\ub9bc\ubc1b\ub358 \uc9d1\uc774 \uae08\uc2f8\ub77c\uae30 \ub418\ub294 \ubc95!"
  ],
  "hook": {
    "text": "\ud83d\udea8\uc7a0\uae50! \ud639\uc2dc \uc694\uc998 \"\uc774\ub7f0 \uc9d1\uc740 \ubb34\uc870\uac74 \ud53c\ud558\uc138\uc694!\" \uac19\uc740 \uc601\uc0c1\uc774\ub098 \ub274\uc2a4\ub97c \ubcf4\uace0 \uacc4\uc2e0\uac00\uc694? \ub9d9\uc18c\uc0ac, \uc9c0\uae08 \ub2f9\uc7a5 \uba48\ucd94\uc138\uc694! \ud83d\ude31 \ub0a8\ub4e4\uc774 \ub2e4 \ud53c\ud558\ub294 \uc9d1\uc5d0 \uc228\uaca8\uc9c4 \uce58\uba85\uc801\uc778 \uc704\ud5d8\u2026 \uadf8\ub9ac\uace0 \uc544\ubb34\ub3c4 \ubaa8\ub974\ub294 \uc5c4\uccad\ub09c \uae30\ud68c\uac00 \ub3d9\uc2dc\uc5d0 \uc874\uc7ac\ud55c\ub2e4\ub294 \uc0ac\uc2e4! \ub2e8\uc21c\ud788 '\ud53c\ud558\ub294 \uac83'\ub9cc\uc774 \ub2a5\uc0ac\uac00 \uc544\ub2d9\ub2c8\ub2e4. \uc798\ubabb \ud53c\ud558\ub2e4\uac00 \uc624\ud788\ub824 \uc190\uc2e4\uc744 \ubcf4\uace0, \ub0a8\ub4e4\uc740 \ub2e4 \ubc84\ub294 \uae30\ud68c\ub97c \ub193\uce60 \uc218\ub3c4 \uc788\uc5b4\uc694. \uc624\ub298 \uc774 \uc601\uc0c1\uc744 \ub05d\uae4c\uc9c0 \ubcf4\uc2dc\uba74, \ubd80\ub3d9\uc0b0 \uc190\uc2e4 \uc704\ud5d8\uc740 \ud604\uba85\ud558\uac8c \ud53c\ud558\uace0, \uc624\ud788\ub824 \uc704\uae30 \uc18d\uc5d0\uc11c \ub2f9\uc2e0\uc758 \uc790\uc0b0\uc744 \ub450 \ubc30\ub85c \ubd88\ub9b4 \uc218 \uc788\ub294 \ube44\ubc00 \uc804\ub7b5\uc744 \uc54c\uac8c \ub420 \uac81\ub2c8\ub2e4! \uc9c0\uae08 \ubc14\ub85c \uc774 \uae34\uae09\ud55c \uc815\ubcf4\uc5d0 \uc9d1\uc911\ud574\uc8fc\uc138\uc694!",
