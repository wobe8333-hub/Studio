    {
      "id": 3,
      "heading": "\ud83d\udca1 \uc5ed\ubc1c\uc0c1 \uae30\ud68c \ud3ec\ucc29: \ub0a8\ub4e4\uc774 \ud53c\ud560 \ub54c \uc9c4\uc9dc \ubcf4\ubb3c\uc744 \ucc3e\ub294 \ubc95",
      "narration_text": "\uc790, \uc774\uc81c \uac00\uc7a5 \uc911\uc694\ud55c \ubd80\ubd84\uc785\ub2c8\ub2e4. \ub0a8\ub4e4\uc774 \ubaa8\ub450 \"\uc774 \uc9d1\uc740 \ud53c\ud558\uc138\uc694!\"\ub77c\uace0 \uc678\uce60 \ub54c, \uc6b0\ub9ac\ub294 \uc5b4\ub5bb\uac8c \uc228\uaca8\uc9c4 \uae30\ud68c\ub97c \ud3ec\ucc29\ud560 \uc218 \uc788\uc744\uae4c\uc694? \ud83d\udc8e \ubc14\ub85c '\uc5ed\ubc1c\uc0c1 \ud22c\uc790'\uc758 \uae30\ud68c\uc785\ub2c8\ub2e4. \uc2dc\uc7a5\uc758 \uc9d1\ub2e8\uc801 \uc2ec\ub9ac\uac00 \ub9cc\ub4e4\uc5b4\ub0b8 \uc800\ud3c9\uac00\ub294 \ubcf8\uc9c8\uc801\uc778 \uac00\uce58\ub97c \uc54c\uc544\ubcf4\ub294 \ud604\uba85\ud55c \ud22c\uc790\uc790\uc5d0\uac8c\ub294 \ud669\uae08 \uac19\uc740 \uae30\ud68c\uac00 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \ud575\uc2ec\uc740 '\uac1d\uad00\uc801\uc778 \uac00\uce58 \ubd84\uc11d'\uacfc '\ubbf8\ub798 \uac00\uce58 \uc608\uce21'\uc5d0 \uc788\uc2b5\ub2c8\ub2e4. \ub2e8\uc21c\ud788 '\ud53c\ud574\uc57c \ud560 \uc9d1'\uc774\ub77c\uace0 \ub099\uc778\ucc0d\ud78c \uacf3\uc774\ub77c\ub3c4, \uad50\ud1b5, \ud559\uad70, \uac1c\ubc1c \ud638\uc7ac, \uc778\ud504\ub77c \uac1c\uc120 \ub4f1\uc758 \uae0d\uc815\uc801\uc778 \uc694\uc18c\ub97c \uac00\uc9c0\uace0 \uc788\ub2e4\uba74, \ud604\uc7ac\uc758 \ubd80\uc815\uc801\uc778 \uc778\uc2dd\uc740 \uc77c\uc2dc\uc801\uc77c \uac00\ub2a5\uc131\uc774 \ud07d\ub2c8\ub2e4. \uc608\ub97c \ub4e4\uc5b4, \uc778\ud504\ub77c \ud655\ucda9 \uacc4\ud68d\uc774 \ubc1c\ud45c\ub418\uc5c8\uc74c\uc5d0\ub3c4 \ubd88\uad6c\ud558\uace0 \uc544\uc9c1 \uc2dc\uc138\uc5d0 \ubc18\uc601\ub418\uc9c0 \uc54a\uc740 \uc9c0\uc5ed, \ub610\ub294 \uc7ac\uac74\ucd95/\uc7ac\uac1c\ubc1c\uc758 \uac00\ub2a5\uc131\uc774 \uc7ac\uc870\uba85\ub420 \uc5ec\uc9c0\uac00 \uc788\ub294 \ub178\ud6c4 \uc544\ud30c\ud2b8 \ub2e8\uc9c0 \ub4f1\uc740 \ub0a8\ub4e4\uc774 \uac70\ub4e4\ub5a0\ubcf4\uc9c0 \uc54a\uc744 \ub54c \ub9e4\ub825\uc801\uc778 \ud22c\uc790\ucc98\uac00 \ub420 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc704\uae30\ub97c \uae30\ud68c\ub85c \ubc14\uafb8\ub824\uba74 \ub0a8\ub4e4\uacfc \ub2e4\ub978 \uc2dc\uac01\uacfc \uc6a9\uae30\uac00 \ud544\uc694\ud569\ub2c8\ub2e4.",
      "animation_prompt": "Dr. Rabby holds a magnifying glass, examining a 'bad house' icon (with an X over it). As Dr. Rabby examines it, the X disappears, and the house icon starts glowing with a hidden gem inside. On the other side, a crowd ignores this house, looking at generic 'good' houses.",
      "animation_style": "comparison",
