{
  "schema_version": "v1",
  "description": "V7.5 thumbnail style registry - thumbnail layout and text policy",
  "entries": [
    {
      "id": "high_contrast_warning",
      "description": "High contrast, attention-grabbing, urgency cue",
      "layout": "centered_text",
      "text_words_max": 6,
      "emphasis_mode": "bold",
      "contrast_mode": "high",
      "face_priority": "optional",
      "banned_patterns": ["cluttered", "low_contrast"]
    },
    {
      "id": "clean_trust",
      "description": "Clean layout, trust-building, professional",
      "layout": "balanced",
      "text_words_max": 8,
      "emphasis_mode": "moderate",
      "contrast_mode": "medium",
      "face_priority": "preferred",
      "banned_patterns": ["sensational", "all_caps"]
    },
    {
      "id": "curiosity_gap",
      "description": "Curiosity gap, open loop, click-friendly",
      "layout": "text_lead",
      "text_words_max": 5,
      "emphasis_mode": "question",
      "contrast_mode": "medium",
      "face_priority": "optional",
      "banned_patterns": ["spoiler", "full_answer_in_thumb"]
    }
  ]
}
