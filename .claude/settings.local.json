{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Bash(ls:*)",
      "WebFetch",
      "WebSearch",
      "WebBrowse",
      "Bash(pip install:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(grep:*)",
      "Bash(pip freeze:*)",
      "Bash(ffmpeg -version)",
      "Read(//c/Users/조찬우/Desktop/ai_stuidio_claude/**)",
      "mcp__context7__*",
      "Skill(update-config)",
      "mcp__playwright__*",
      "mcp__figma__*",
      "mcp__plugin_github_github__create_repository",
      "Bash(cat)",
      "Bash(echo \"exit: $?\")",
      "Bash(mkdir -p .claude/agent-logs)",
      "Bash(touch .claude/agent-logs/.gitkeep)",
      "Read(//c/Users/조찬우/.claude/agent-memory//**)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[v8:SubagentStop] $(date +%H:%M:%S)\" >> \"C:/Users/조찬우/Desktop/ai_stuidio_claude/.claude/agent-logs/hooks.log\" 2>/dev/null || true",
            "async": true
          },
          {
            "type": "command",
            "command": "cd \"C:/Users/조찬우/Desktop/ai_stuidio_claude\" && python -m pytest tests/ -x -q --ignore=tests/test_step08_integration.py 2>&1 | tail -10",
            "async": true
          },
          {
            "type": "command",
            "command": "cd \"C:/Users/조찬우/Desktop/ai_stuidio_claude\" && ruff check src/ --fix --select=E,W,F,I 2>&1 | tail -5",
            "async": true
          },
          {
            "type": "command",
            "command": "cd \"C:/Users/조찬우/Desktop/ai_stuidio_claude/web\" && npm run build 2>&1 | tail -10",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.loads(sys.stdin.read()); p=d.get('input',{}).get('file_path','').replace('\\\\','/'); blocked=['.env','credentials/','_token.json','step08/__init__.py']; sys.exit(2) if any(b in p for b in blocked) else sys.exit(0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/조찬우/Desktop/ai_stuidio_claude\" && git diff --stat HEAD 2>/dev/null | tail -5",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"C:/Users/조찬우/Desktop/ai_stuidio_claude\" && python scripts/mission_probe.py 2>&1 | tail -20",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/조찬우/Desktop/ai_stuidio_claude/.claude/hooks/session_end.py\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[v8:Stop] $(date +%H:%M:%S)\" >> \"C:/Users/조찬우/Desktop/ai_stuidio_claude/.claude/agent-logs/hooks.log\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/조찬우/Desktop/ai_stuidio_claude/.claude/hooks/detect_hitl.py\"",
            "async": false
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/조찬우/Desktop/ai_stuidio_claude/.claude/hooks/save_reflection.py\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  }
}
