# KAS 에디터 설정 — 모든 에디터/IDE에서 일관성 유지
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
