# ============================================================
# KAS (Knowledge Animation Studio) 환경 변수 예시
# 실제 키를 .env 파일에 복사하여 사용하세요.
# .env 파일은 .gitignore에 의해 추적 제외됩니다.
# ============================================================

# ── 필수 API 키 ──────────────────────────────────────────────

# YouTube Data API v3 + YouTube Analytics API
# Google Cloud Console에서 발급
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# YouTube 채널 ID (CH1~CH7)
CH1_CHANNEL_ID=YOUR_CH1_CHANNEL_ID
CH2_CHANNEL_ID=YOUR_CH2_CHANNEL_ID
CH3_CHANNEL_ID=YOUR_CH3_CHANNEL_ID
CH4_CHANNEL_ID=YOUR_CH4_CHANNEL_ID
CH5_CHANNEL_ID=YOUR_CH5_CHANNEL_ID
CH6_CHANNEL_ID=YOUR_CH6_CHANNEL_ID
CH7_CHANNEL_ID=YOUR_CH7_CHANNEL_ID

# Google Gemini API
# Google AI Studio에서 발급
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Anthropic Claude API (LLM 이중화 fallback — Gemini 장애 시 자동 전환)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# 사용할 Gemini 이미지 모델 (기본값)
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ── Phase 1: 모니터링 ──────────────────────────────────────────

# Sentry 에러 추적 (선택, 비워두면 비활성화)
# https://sentry.io 에서 프로젝트 생성 후 발급
SENTRY_DSN=

# ── Phase 3: 트렌드 수집 소스 API 키 ─────────────────────────

# SerpAPI - Google Trends 수집 ($50/월, 선택)
# https://serpapi.com 에서 발급
SERPAPI_KEY=

# Reddit API (PRAW) - 무료, 60콜/분
# https://www.reddit.com/prefs/apps 에서 앱 등록
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=KAS-TrendBot/3.0

# Naver Search API - 무료, 25,000콜/일
# https://developers.naver.com 에서 애플리케이션 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# NASA Open API - 무료 (DEMO_KEY는 분당 30콜 제한)
# https://api.nasa.gov 에서 발급
NASA_API_KEY=DEMO_KEY

# ── Phase 4: 지식 수집 API 키 (미래 구현) ────────────────────

# Tavily AI Search - AI 웹 검색 ($5/1K콜)
# https://tavily.com 에서 발급
TAVILY_API_KEY=

# Perplexity API - AI 리서치 ($5/월 Pro)
# https://www.perplexity.ai 에서 발급
PERPLEXITY_API_KEY=

# ── Phase 6: 음성 합성 API 키 (미래 구현) ────────────────────

# ElevenLabs TTS - 고품질 한국어 음성 ($5~22/월)
# https://elevenlabs.io 에서 발급
ELEVENLABS_API_KEY=

# ElevenLabs 채널별 캐릭터 Voice ID (pipeline_v2 — 14 목소리)
# ElevenLabs > Voices > Voice Settings 에서 voice_id 복사
# Narrator: 채널 톤 리드 보이스 (신뢰감/전문성)
# Guest: 대조적 개성 (연령·성별·음색 대비)
CH1_NARRATOR_VOICE_ID=YOUR_CH1_NARRATOR_VOICE_ID  # 경제 — 30대 남성 신뢰감
CH1_GUEST_VOICE_ID=YOUR_CH1_GUEST_VOICE_ID        # 경제 — 20대 여성 호기심
CH2_NARRATOR_VOICE_ID=YOUR_CH2_NARRATOR_VOICE_ID  # 과학 — 40대 남성 침착
CH2_GUEST_VOICE_ID=YOUR_CH2_GUEST_VOICE_ID        # 과학 — 20대 남성 열정
CH3_NARRATOR_VOICE_ID=YOUR_CH3_NARRATOR_VOICE_ID  # 부동산 — 40대 여성 신뢰
CH3_GUEST_VOICE_ID=YOUR_CH3_GUEST_VOICE_ID        # 부동산 — 30대 남성 실용
CH4_NARRATOR_VOICE_ID=YOUR_CH4_NARRATOR_VOICE_ID  # 심리 — 30대 여성 힐링
CH4_GUEST_VOICE_ID=YOUR_CH4_GUEST_VOICE_ID        # 심리 — 30대 남성 중립
CH5_NARRATOR_VOICE_ID=YOUR_CH5_NARRATOR_VOICE_ID  # 미스터리 — 30대 남성 서스펜스
CH5_GUEST_VOICE_ID=YOUR_CH5_GUEST_VOICE_ID        # 미스터리 — 40대 여성 의문
CH6_NARRATOR_VOICE_ID=YOUR_CH6_NARRATOR_VOICE_ID  # 역사 — 50대 남성 장엄
CH6_GUEST_VOICE_ID=YOUR_CH6_GUEST_VOICE_ID        # 역사 — 30대 여성 명료
CH7_NARRATOR_VOICE_ID=YOUR_CH7_NARRATOR_VOICE_ID  # 전쟁사 — 40대 남성 긴장
CH7_GUEST_VOICE_ID=YOUR_CH7_GUEST_VOICE_ID        # 전쟁사 — 50대 남성 무게감

# ── 시스템 설정 ──────────────────────────────────────────────

# KAS 루트 디렉토리 (절대경로)
KAS_ROOT=C:\Users\사용자명\Desktop\ai_stuidio_claude

# YouTube API 실패 처리 (0=무중단, 1=즉시 실패)
REQUIRE_YOUTUBE_OK=0
ALLOW_YOUTUBE_FAIL=0

# ── Supabase (웹 대시보드 연동) ───────────────────────────────
# https://supabase.com 에서 프로젝트 생성 후 발급

# Python sync 스크립트용 (서버사이드)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Next.js 웹 대시보드용 (web/.env.local 에도 동일하게 설정)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ─── Loomix v10.0 신규 (Slack + 기능 플래그) ───────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_DIGEST_CHANNEL=#loomix-ops
BUDGET_LIMIT_USD=50
ENABLE_CRON=true
ENABLE_CHAOS=false
AGENT_WRITE_LIMIT=50

# ─── pipeline_v2 G2 신규 API (v2.1) ────────────────────────

# Suno AI BGM 생성 ($10/월 구독)
# https://suno.ai > Settings > API 에서 발급
SUNO_API_KEY=YOUR_SUNO_API_KEY_HERE

# Figma MCP 템플릿 자동화
# Figma > Account Settings > Personal Access Tokens
FIGMA_TOKEN=YOUR_FIGMA_TOKEN_HERE

# Figma 마스터 템플릿 파일 ID (URL의 /file/{ID}/ 부분)
FIGMA_MASTER_FILE_ID=YOUR_FIGMA_FILE_ID_HERE

# Replicate API (G3 Phase용 placeholder — Phase 1에서는 미사용)
# https://replicate.com/account/api-tokens
REPLICATE_TOKEN=YOUR_REPLICATE_TOKEN_PLACEHOLDER
