# YouTube API Key (필수)
# Google Cloud Console에서 YouTube Data API v3 키를 발급받아 설정하세요.
YOUTUBE_API_KEY=YOUR_KEY_HERE

# YouTube 키 오류 시 즉시 실패 여부 (기본값: 0=무중단, 1=FAIL)
# REQUIRE_YOUTUBE_OK=1로 설정하면 keyExpired/quotaExceeded 발생 시 즉시 실패합니다.
REQUIRE_YOUTUBE_OK=0

# YouTube 실패 허용 여부 (기본값: 0=실패 시 에러, 1=빈 bucket 반환)
# ALLOW_YOUTUBE_FAIL=1로 설정하면 YouTube 오류 시 빈 bucket을 반환하여 파이프라인을 계속 진행합니다.
ALLOW_YOUTUBE_FAIL=0
